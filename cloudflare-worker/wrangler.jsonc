{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mekong-district-leads",
  "main": "src/index.js",
  "compatibility_date": "2026-07-20",
  "workers_dev": true,
  "preview_urls": false,
  "ratelimits": [
    {
      "name": "LEAD_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 3,
        "period": 60
      }
    }
  ]
}
